# ─────────────────────────────────────────────────────────────
# CredChain — root .gitignore (applies recursively to all services)
# ─────────────────────────────────────────────────────────────

# Node dependencies (any depth: /node_modules, /backend/node_modules, ...)
**/node_modules/
node_modules/

# Environment variables (never commit secrets / wallet keys)
**/.env
**/.env.*
!**/.env.example
.env
.env.*
!.env.example

# Python virtual environments
**/venv/
**/.venv/
**/env/
**/ENV/
venv/
.venv/
env/

# Python bytecode / caches
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Production build / dist outputs
**/dist/
**/build/
**/.vite/
dist/
build/

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Solana local wallet keypairs (NEVER commit private keys)
**/*.keypair.json
**/id.json
